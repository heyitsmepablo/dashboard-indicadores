# ==============================================================================
# 🗄️ DATABASE CONFIGURATION (Prisma / PostgreSQL)
# ==============================================================================
# Prisma supports the native connection string format for PostgreSQL.
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
# Ajuste as credenciais (postgres:postgres) e o nome do banco (dashify) conforme o seu docker-compose.yml
DATABASE_URL=""

# ==============================================================================
# 🔐 AUTHENTICATION & SECURITY (JWT)
# ==============================================================================
# Chave secreta para assinatura dos tokens JWT. (Troque por uma string forte em produção)
JWT_SECRET="#"
# Tempo de expiração do token do usuário logado
JWT_EXPIRATION=""

# ==============================================================================
# 🤖 INTEGRAÇÃO DE INTELIGÊNCIA ARTIFICIAL (n8n + Gemini)
# ==============================================================================
# URL do webhook criado no n8n para receber os dados do indicador e gerar a análise.
# Como o NestJS e o n8n estão rodando localmente, o localhost ou host.docker.internal funciona aqui.
N8N_WEBHOOK_URL=""

# ==============================================================================
# 🚀 SERVER CONFIGURATION
# ==============================================================================
PORT=